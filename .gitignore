# ── Dependencies ─────────────────────────────────────────────────
node_modules/
**/node_modules/

# ── Environment variables (NEVER commit these) ───────────────────
.env
.env.*
!.env.example
**/.env
**/.env.*
!**/.env.example

# ── Build outputs ─────────────────────────────────────────────────
dist/
dist-ssr/
build/
**/dist/
**/build/

# ── Vite cache ────────────────────────────────────────────────────
**/.vite/
**/.vite-temp/

# ── Logs ──────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── OS files ──────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Editor ────────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── Misc ──────────────────────────────────────────────────────────
*.local
*.tgz
*.zip
